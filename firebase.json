{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "etickette",
    "public": "website",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "serviceAccountsKey.json",
      "python/**",
      "**/*.exe",
      "**/*.dll",
      "**/*.py",
      "**/*.bat",
      ".github/**",
      "**/.venv/**"
    ],
    "headers": [
      {
        "source": "/OneSignalSDKWorker.js",
        "headers": [
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          },
          {
            "key": "Content-Type",
            "value": "application/javascript"
          }
        ]
      }
    ]
  }
}