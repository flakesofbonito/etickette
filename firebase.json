{
  "hosting": {
    "site": "etickette",
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "serviceAccountsKey.json",
      "python/**",
      "**/*.exe",
      "**/*.dll",
      "**/*.py",
      "**/*.bat",
      ".github/**",
      "**/.venv/**"
    ]
  }
}