{
  "hosting": {
    "site": "etickette",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "serviceAccountsKey.json",
      "python/**",
      "**/*.exe",
      "**/*.dll",
      "**/*.py",
      "**/*.bat",
      ".github/**",
      "**/.venv/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/website/index.html"
      }
    ]
  }
}