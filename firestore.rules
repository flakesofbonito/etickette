rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // DEPARTMENTS
    // =========================
    match /departments/{dept} {
      allow read: if true;

      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'status',
          'counter',
          'queue',
          'nowServing',
          'avgWaitSeconds',
          'lastResetAt'
        ]);

      allow create, delete: if false;
    }

    // =========================
    // SYSTEM SETTINGS
    // =========================
    match /system/{doc} {
      allow read: if true;

      allow update: if
        // Normal field writes (statusMessage, dailyQuota, pins, etc.)
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'ticketsIssued',
            'dailyQuota',
            'statusMessage',
            'statusMessageAt',
            'staffPin',
            'monitorPin'
          ])
        ||
        // FieldValue.increment() is a server-side transform — Firestore sends
        // it with an empty updateMask (fieldPaths: []), so affectedKeys()
        // returns size 0. We must allow this, otherwise issuing a ticket
        // from the Kiosk fails with "permission-denied".
        request.resource.data.diff(resource.data).affectedKeys().size() == 0;

      allow create, delete: if false;
    }

    // =========================
    // TICKETS
    // =========================
    match /tickets/{ticketId} {
      allow read: if true;
      allow delete: if false;

      allow create: if
        request.resource.data.ticketNumber is string &&
        request.resource.data.department in ['cashier','registrar'] &&
        request.resource.data.userId is string &&
        request.resource.data.status == 'waiting';

      allow update: if
        request.resource.data.ticketNumber == resource.data.ticketNumber &&
        request.resource.data.department == resource.data.department &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.status in [
          'waiting',
          'serving',
          'completed',
          'noshow',
          'cancelled'
        ];
    }

    // =========================
    // RESERVATIONS
    // =========================
    match /reservations/{resId} {
      allow read: if true;
      allow delete: if false;

      allow create: if
        request.resource.data.department in ['cashier','registrar'] &&
        request.resource.data.status == 'pending' &&
        request.resource.data.studentId is string;

      allow update: if
        request.resource.data.department == resource.data.department &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.status in [
          'pending',
          'active',
          'completed',
          'cancelled',
          'expired',
          'noshow'
        ];
    }

  }
}
