rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /departments/{dept} {
      allow read:   if true;
      allow create: if false;
      allow delete: if false;
      allow update: if true;
    }

    match /system/{doc} {
      allow read:   if true;
      allow create: if false;
      allow delete: if false;
      allow update: if !request.resource.data.diff(resource.data).affectedKeys().hasAny(['staffPin', 'monitorPin']);
    }

    match /tickets/{ticketId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /reservations/{resId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
  }
}